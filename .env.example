# === Aplicación ===
APP_NAME=PQRS API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# === Seguridad / JWT ===
SECRET_KEY=cambia-esta-llave-por-una-larga-y-aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# === CORS ===
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# === Base de datos ===
POSTGRES_USER=pqrs_user
POSTGRES_PASSWORD=pqrs_pass
POSTGRES_DB=pqrs_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://pqrs_user:pqrs_pass@localhost:5432/pqrs_db

# === Superusuario inicial ===
FIRST_ADMIN_EMAIL=admin@pqrs.local
FIRST_ADMIN_PASSWORD=Admin123*
FIRST_ADMIN_NAME=Administrador

# === SMTP ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@pqrs.local
SMTP_TLS=true
SMTP_ENABLED=false

# === Notificaciones por área ===
# Puedes separar varios correos con coma, punto y coma o espacio.
CALIDAD_EMAILS=calidad1@empresa.com,calidad2@empresa.com
LOGISTICA_EMAILS=logistica@empresa.com
COMERCIAL_EMAILS=comercial@empresa.com

# === Almacenamiento ===
STORAGE_BACKEND=local         # local | s3
UPLOAD_DIR=app/uploads
MAX_UPLOAD_MB=10

# === S3 (opcional) ===
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
